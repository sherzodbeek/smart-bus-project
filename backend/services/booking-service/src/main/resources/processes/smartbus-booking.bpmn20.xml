    <sequenceFlow id="flow8" sourceRef="prepareNotification" targetRef="parallelJoin"/>
    <sequenceFlow id="flow9" sourceRef="parallelJoin" targetRef="checkPaymentDecision"/>
    <sequenceFlow id="flow10" sourceRef="checkPaymentDecision" targetRef="dispatchNotification"/>
    <sequenceFlow id="flow11" sourceRef="dispatchNotification" targetRef="finalizeBooking"/>
    <sequenceFlow id="flow12" sourceRef="finalizeBooking" targetRef="endBooking"/>
  </process>
