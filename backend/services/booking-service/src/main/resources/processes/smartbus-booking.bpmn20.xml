    <serviceTask id="validateSchedule" name="Validate Schedule" flowable:delegateExpression="${validateScheduleDelegate}"/>
    <serviceTask id="recordParallelFlow" name="Record Parallel Flow" flowable:delegateExpression="${parallelFlowDelegate}"/>
    <parallelGateway id="parallelSplit" name="Parallel Split"/>
    <serviceTask id="authorizePayment" name="Authorize Payment" flowable:delegateExpression="${authorizePaymentDelegate}"/>
    <serviceTask id="prepareNotification" name="Prepare Notification" flowable:delegateExpression="${prepareNotificationDelegate}"/>
    <parallelGateway id="parallelJoin" name="Parallel Join"/>
    <serviceTask id="checkPaymentDecision" name="Check Payment Decision" flowable:delegateExpression="${checkPaymentDecisionDelegate}"/>
