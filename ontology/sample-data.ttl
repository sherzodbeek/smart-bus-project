# ═══════════════════════════════════════════════════════════════════════════════
# 6. Inferred user preference triples  (Rule R1 + R2 results)
#
# These would normally be derived by the preprocessing pipeline and asserted here
# after running inference.  They are included explicitly to enable SPARQL queries
# on the knowledge graph without requiring a running reasoner.
# ═══════════════════════════════════════════════════════════════════════════════

# Rule R2 — prefersOrigin (most common departure stop per user)
sb:User_Alice sb:prefersOrigin sb:Stop_DowntownTerminal .
sb:User_Bob   sb:prefersOrigin sb:Stop_CityCenter .
sb:User_Carol sb:prefersOrigin sb:Stop_University .
sb:User_David sb:prefersOrigin sb:Stop_BusDepot .
sb:User_Eve   sb:prefersOrigin sb:Stop_BusDepot .

# Rule R1 — frequentlyTravels (≥3 completed bookings on same route)
sb:User_Alice sb:frequentlyTravels sb:Route_SB101 .   # 4 bookings
sb:User_Alice sb:frequentlyTravels sb:Route_SB102 .   # 3 bookings
sb:User_Bob   sb:frequentlyTravels sb:Route_SB203 .   # 3 bookings
sb:User_Carol sb:frequentlyTravels sb:Route_SB202 .   # 2 bookings (sample; full dataset has 3)
sb:User_Eve   sb:frequentlyTravels sb:Route_SB302 .   # 3 bookings

# ═══════════════════════════════════════════════════════════════════════════════
# 7. Zone proximity (Rule R3 — SPARQL CONSTRUCT result, asserted for query support)
# ═══════════════════════════════════════════════════════════════════════════════

# Central zone: Downtown Terminal ↔ City Center
sb:Stop_DowntownTerminal sb:inSameZoneAs sb:Stop_CityCenter .
sb:Stop_CityCenter       sb:inSameZoneAs sb:Stop_DowntownTerminal .

# Northern zone: Airport Station ↔ University
sb:Stop_AirportStation sb:inSameZoneAs sb:Stop_University .
sb:Stop_University     sb:inSameZoneAs sb:Stop_AirportStation .

# Southern zone: Bus Depot ↔ Harbor
sb:Stop_BusDepot sb:inSameZoneAs sb:Stop_Harbor .
sb:Stop_Harbor   sb:inSameZoneAs sb:Stop_BusDepot .

# ═══════════════════════════════════════════════════════════════════════════════
# 8. AI Recommendations  (stored as first-class RDF entities — Rule R5 applied)
# ═══════════════════════════════════════════════════════════════════════════════

# Alice: SB-101 recommended (HIGH — she frequentlyTravels it)
sb:Rec_Alice_SB101 a sb:Recommendation ;
    sb:forUser         sb:User_Alice ;
    sb:suggestsRoute   sb:Route_SB101 ;
    sb:confidenceScore "0.81"^^xsd:decimal ;
    sb:confidenceLevel "HIGH" ;
    sb:reasonCode      "collaborative_match" .

# Alice: SB-103 recommended (MEDIUM — content match for Downtown departures)
sb:Rec_Alice_SB103 a sb:Recommendation ;
    sb:forUser         sb:User_Alice ;
    sb:suggestsRoute   sb:Route_SB103 ;
    sb:confidenceScore "0.47"^^xsd:decimal ;
    sb:confidenceLevel "MEDIUM" ;
    sb:reasonCode      "content_match" .

# Bob: SB-303 recommended (HIGH — City Center departure, HIGH tier preference)
sb:Rec_Bob_SB303 a sb:Recommendation ;
    sb:forUser         sb:User_Bob ;
    sb:suggestsRoute   sb:Route_SB303 ;
    sb:confidenceScore "0.73"^^xsd:decimal ;
    sb:confidenceLevel "HIGH" ;
    sb:reasonCode      "content_match" .

# Carol: SB-304 recommended (MEDIUM — University departure, occasional user)
sb:Rec_Carol_SB304 a sb:Recommendation ;
    sb:forUser         sb:User_Carol ;
    sb:suggestsRoute   sb:Route_SB304 ;
    sb:confidenceScore "0.38"^^xsd:decimal ;
    sb:confidenceLevel "MEDIUM" ;
    sb:reasonCode      "content_match" .

# David: SB-301 recommended (LOW — rare user, popularity fallback)
sb:Rec_David_SB301 a sb:Recommendation ;
    sb:forUser         sb:User_David ;
    sb:suggestsRoute   sb:Route_SB301 ;
    sb:confidenceScore "0.21"^^xsd:decimal ;
    sb:confidenceLevel "LOW" ;
    sb:reasonCode      "popularity_fallback" .
