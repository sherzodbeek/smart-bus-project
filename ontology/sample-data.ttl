# SmartBus Sample Instance Data  (ABox)
# Companion to: ontology/smartbus-ontology.ttl
# Purpose: Populate the knowledge graph with representative SmartBus entities for
#          testing inference rules, SPARQL queries, and the semantic data layer.
#
# Entity counts:
#   Users          : 5  (commuter × 2, frequent × 1, occasional × 1, rare × 1)
#   Buses          : 4
#   Bookings       : 14 (enough to trigger R1 frequency rules)
#   Payments       : 14
#   Recommendations: 5  (HIGH × 2, MEDIUM × 2, LOW × 1)
#   Inferred triples: prefersOrigin × 5, frequentlyTravels × 7, inSameZoneAs × 6
#
# Total instance triples: ~160 (all ABox; TBox is in smartbus-ontology.ttl)

@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix sb:   <http://smartbus.example.org/ontology#> .

# ═══════════════════════════════════════════════════════════════════════════════
# 1. Users
# ═══════════════════════════════════════════════════════════════════════════════

sb:User_Alice a sb:User ;
    sb:email         "alice@smartbus.test" ;
    sb:fullName      "Alice Nguyen" ;
    sb:travelProfile "commuter" .

sb:User_Bob a sb:User ;
    sb:email         "bob@smartbus.test" ;
    sb:fullName      "Bob Okafor" ;
    sb:travelProfile "frequent" .

sb:User_Carol a sb:User ;
    sb:email         "carol@smartbus.test" ;
    sb:fullName      "Carol Petrov" ;
    sb:travelProfile "occasional" .

sb:User_David a sb:User ;
    sb:email         "david@smartbus.test" ;
    sb:fullName      "David Lim" ;
    sb:travelProfile "rare" .

sb:User_Eve a sb:User ;
    sb:email         "eve@smartbus.test" ;
    sb:fullName      "Eve Santos" ;
    sb:travelProfile "commuter" .

# ═══════════════════════════════════════════════════════════════════════════════
# 2. Buses
# ═══════════════════════════════════════════════════════════════════════════════

sb:Bus_BUS01 a sb:Bus ;
    sb:busPlate      "ABC-1234" ;
    sb:seatCapacity  50 .

sb:Bus_BUS02 a sb:Bus ;
    sb:busPlate      "DEF-5678" ;
    sb:seatCapacity  45 .

sb:Bus_BUS03 a sb:Bus ;
    sb:busPlate      "GHI-9012" ;
    sb:seatCapacity  55 .

sb:Bus_BUS04 a sb:Bus ;
    sb:busPlate      "JKL-3456" ;
    sb:seatCapacity  40 .

# ═══════════════════════════════════════════════════════════════════════════════
# 3. Route–Bus assignments (operatedBy)
# ═══════════════════════════════════════════════════════════════════════════════

sb:Route_SB101 sb:operatedBy sb:Bus_BUS01 .
sb:Route_SB102 sb:operatedBy sb:Bus_BUS02 .
sb:Route_SB103 sb:operatedBy sb:Bus_BUS03 .
sb:Route_SB201 sb:operatedBy sb:Bus_BUS01 .
sb:Route_SB202 sb:operatedBy sb:Bus_BUS02 .
sb:Route_SB203 sb:operatedBy sb:Bus_BUS03 .
sb:Route_SB301 sb:operatedBy sb:Bus_BUS04 .
sb:Route_SB302 sb:operatedBy sb:Bus_BUS01 .
sb:Route_SB303 sb:operatedBy sb:Bus_BUS02 .
sb:Route_SB304 sb:operatedBy sb:Bus_BUS03 .

# ═══════════════════════════════════════════════════════════════════════════════
# 4. Bookings  (14 instances)
#
# Alice (commuter, Downtown Terminal):
#   4 × SB-101, 3 × SB-102   → frequentlyTravels SB-101, SB-102
# Bob (frequent, City Center):
#   4 × SB-203, 3 × SB-303   → frequentlyTravels SB-203, SB-303
# Carol (occasional, University):
#   3 × SB-202                → frequentlyTravels SB-202
# David (rare):   1 × SB-302
# Eve (commuter, Bus Depot):  3 × SB-302   → frequentlyTravels SB-302
#
# (Full booking history lives in the relational DB; these triples are a
#  representative sample for semantic layer testing.)
# ═══════════════════════════════════════════════════════════════════════════════

# Alice – SB-101 (×4)
sb:Booking_BK001 a sb:Booking ;
    sb:bookingReference "BK-001" ;
    sb:tripDate         "2026-03-10"^^xsd:date ;
    sb:bookingStatus    "COMPLETED" ;
    sb:passengers       1 ;
    sb:totalAmount      "15.00"^^xsd:decimal ;
    sb:onRoute          sb:Route_SB101 ;
    sb:paidWith         sb:Payment_TX001 .
sb:User_Alice sb:hasBooking sb:Booking_BK001 .
sb:Booking_BK001 sb:bookedBy sb:User_Alice .

